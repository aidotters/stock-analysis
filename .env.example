# Stock-Analysis Configuration
# Copy this file to .env and update with your values

# ============================================================
# CREDENTIALS (Required)
# ============================================================

# J-Quants API credentials
EMAIL=your_email@example.com
PASSWORD=your_password

# EDINET API key (for executive master updates)
# 取得: https://disclosure2.edinet-fsa.go.jp/ のAPI利用申請ページから取得
EDINET_API_KEY=your-edinet-api-key

# ============================================================
# OPTIONAL OVERRIDES
# ============================================================
# All settings below have sensible defaults. Only uncomment
# and modify if you need to change the default behavior.

# --- J-Quants API Settings ---
# JQUANTS_MAX_CONCURRENT_REQUESTS=3
# JQUANTS_BATCH_SIZE=100
# JQUANTS_REQUEST_DELAY=0.1
# JQUANTS_TIMEOUT_SECONDS=30
# JQUANTS_CACHE_TTL_HOURS=24

# --- yfinance API Settings ---
# YFINANCE_MAX_WORKERS=1          # 1 = sequential (recommended to avoid rate limits)
# YFINANCE_RATE_LIMIT_DELAY=2.0   # seconds between requests
# YFINANCE_VALUATION_BATCH_SIZE=150  # stocks per rolling update
# YFINANCE_VALUATION_WAIT_SECONDS=0.5  # wait between API calls
# YFINANCE_VALUATION_MAX_WORKERS=4  # parallel fetch threads

# --- Analysis Parameters ---
# ANALYSIS_RSP_PERIOD_DAYS=500
# ANALYSIS_UPDATE_WINDOW_DAYS=5
# ANALYSIS_HL_RATIO_WEEKS=52
# ANALYSIS_TRADING_DAYS_PER_YEAR=260
# ANALYSIS_SMA_SHORT=50
# ANALYSIS_SMA_MEDIUM=150
# ANALYSIS_SMA_LONG=200
# ANALYSIS_TYPE6_THRESHOLD=1.3
# ANALYSIS_TYPE7_THRESHOLD=0.75
# ANALYSIS_TYPE8_RSI_THRESHOLD=70

# --- Database Settings ---
# SQLITE_JOURNAL_MODE=WAL
# SQLITE_SYNCHRONOUS=NORMAL
# SQLITE_CACHE_SIZE=10000
# SQLITE_MMAP_SIZE=268435456

# --- Logging ---
# LOG_LEVEL=INFO
# LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# --- EDINET API Settings ---
# EDINET_BASE_URL=https://api.edinet-fsa.go.jp/api/v2
# EDINET_TIMEOUT_LIST=30
# EDINET_TIMEOUT_DOWNLOAD=120
# EDINET_MAX_RETRIES=3

# --- Executives Settings ---
# EXECUTIVES_CACHE_TTL_DAYS=30                 # 発信コンテンツの再収集TTL
# EXECUTIVES_MAX_PARALLEL_FETCH=3              # 月次バッチ時の並列度
# EXECUTIVES_DOC_SCAN_FALLBACK_MONTHS=18       # doc_idキャッシュ外し時の遡及範囲
# EXECUTIVES_DOC_SCAN_NARROW_DAYS=30           # キャッシュ有時の期末前後スキャン日数

# --- Slack Notification Settings ---
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# SLACK_ERROR_WEBHOOK_URL=                # Optional: separate channel for errors
# SLACK_ENABLED=true                      # Set to false to disable notifications
# SLACK_TIMEOUT_SECONDS=10
# SLACK_MAX_RETRIES=3

# --- Path Overrides (usually not needed) ---
# STOCK_ANALYSIS_BASE_DIR=/path/to/project
# STOCK_ANALYSIS_DATA_DIR=/path/to/data
# STOCK_ANALYSIS_LOGS_DIR=/path/to/logs
